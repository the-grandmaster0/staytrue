# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Build output ──────────────────────────────────────────────────────────────
dist/
dist-ssr/

# ── Environment variables (NEVER commit real secrets) ─────────────────────────
.env
.env.local
.env.*.local

# .env.example is SAFE to commit — it contains only placeholder values
# !.env.example  ← intentionally NOT ignored

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Editor / OS ───────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Supabase CLI ──────────────────────────────────────────────────────────────
# Generated by `supabase link` — machine-specific, never commit
supabase/.temp/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.local

# ── Markdown docs (except README) ─────────────────────────────────────────────
*.md
!README.md
